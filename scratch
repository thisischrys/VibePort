import protobuf from 'protobufjs'
import fs from 'node:fs'
import path from 'node:path'

try {
  const bundlePath = path.join('node_modules', 'blizzard-product-parser', 'src', 'assets', 'bundle.json')
  const desc = JSON.parse(fs.readFileSync(bundlePath, 'utf8'))
  const Root = protobuf.Root.fromJSON(desc)
  const Database = Root.lookupType('Database')
  
  const dbPath = path.join(process.env.PROGRAMDATA || 'C:\\ProgramData', 'Battle.net\\Agent\\product.db')
  if (fs.existsSync(dbPath)) {
    const buffer = fs.readFileSync(dbPath)
    const message = Database.decode(buffer)
    const object = Database.toObject(message, {
      defaults: true,
      longs: String,
      enums: String,
      bytes: String
    })
    console.log('Decoded successfully!')
    console.log(JSON.stringify(object, null, 2))
  } else {
    console.log('product.db not found.')
  }
} catch (err) {
  console.error('Error:', err)
}
